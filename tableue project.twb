      </column>
      <column caption='Customers' datatype='integer' name='[Calculation_0964021664636929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Customer.ID])' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_0964021664993282]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0964021665316867]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNTD([Order.ID])' />
      </column>
