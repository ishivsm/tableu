      <aliases enabled='yes' />
      <column caption='cost' datatype='real' name='[Calculation_0874405008089088]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Sales]-[Profit]' />
      </column>
      <column caption='profit ratio' datatype='real' name='[Calculation_0874405008191489]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit]/[Sales]*100' />
      </column>
      <column caption='discount amt' datatype='real' name='[Calculation_0874405008433154]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Quantity]*[UnitPrice]*[Discount]' />
      </column>
      <column caption='sales as per unit' datatype='real' name='[Calculation_0874405008670723]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Sales]/[Quantity]' />
      </column>
      <column caption='profit flag' datatype='string' name='[Calculation_0874405008818180]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF Profit &gt; 0 THEN &quot;profitable&quot;&#13;&#10;ELSE &quot;loss&quot;&#13;&#10;END' />
      </column>
      <column caption='discount tier' datatype='string' name='[Calculation_0874405009195013]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Discount] = 0 THEN &quot;No Discount&quot;&#13;&#10;ELSEIF [Discount] &gt;= 0.15 THEN &quot;Low&quot;&#13;&#10;ELSEIF [Discount]&gt;0.15 THEN &quot;high&quot;&#13;&#10;END' />
      </column>
      <column caption='region grp' datatype='string' name='[Calculation_0874405010432006]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Region]&#13;&#10;WHEN &quot;East&quot; THEN &quot;Coastal&quot;&#13;&#10;WHEN &quot;West&quot; THEN &quot;Coastal&quot;&#13;&#10;WHEN &quot;South&quot; THEN &quot;Inland&quot;&#13;&#10;WHEN &quot;North&quot; THEN &quot;Inland&quot;&#13;&#10;END' />
      </column>
      <column caption='high value' datatype='string' name='[Calculation_0874405010931719]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales]&gt;1000 THEN&quot;yes&quot;&#13;&#10;ELSE &quot;no&quot;&#13;&#10;END' />
      </column>
      <column caption='customer intials' datatype='string' name='[Calculation_0874405011247112]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='UPPER(LEFT([CustomerName],1)+&#13;&#10;MID([CustomerName],FIND([CustomerName],&quot; &quot;)+1,1))' />
      </column>
      <column caption='product  code' datatype='string' name='[Calculation_0874405011845129]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0874405011247112]' />
      </column>
      <column caption='product code' datatype='string' name='[Calculation_0874405012033546]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Category]+ &quot;-&quot; + [SubCategory]' />
      </column>
      <column caption='order month' datatype='string' name='[Calculation_0874405012459531]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR(DATEPART(&apos;year&apos;,[OrderDate]))+ &quot;-&quot; +&#13;&#10;RIGHT(&quot;0&quot;+ STR(DATEPART(&apos;month&apos;,[OrderDate])),2)' />
      </column>
      <column caption='shipdate' datatype='integer' name='[Calculation_0874405013680140]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[OrderDate],[ShipDate])' />
      </column>
      <column caption='orderquater' datatype='integer' name='[Calculation_0874405014294541]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&quot;quarter&quot;,[OrderDate])' />
      </column>
      <column caption='region filter tool' datatype='boolean' name='[Calculation_0874405019443218]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Region]=[Parameters].[Parameter 0874405017845775]' />
      </column>
      <column caption='category filter' datatype='boolean' name='[Calculation_0874405023965210]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Category]=[Parameters].[Parameter 0874405023858713]' />
      </column>
      <column caption='subcatwegory filter' datatype='boolean' name='[Calculation_0874405024276509]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[SubCategory]=[Parameters].[Parameter 0874405024202780]' />
      </column>
      <column caption='Customer Name' datatype='string' name='[CustomerName]' role='dimension' type='nominal' />
      <column caption='Order Date' datatype='date' name='[OrderDate]' role='dimension' type='ordinal' />
      <column caption='Order ID' datatype='string' name='[OrderID]' role='dimension' type='nominal' />
